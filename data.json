Private Sub PoserEntete(ws As Worksheet, ByRef titres As Variant)
    Dim j As Long
    
    For j = 0 To UBound(titres)
        With ws.Cells(1, j + 1)
            .Value = titres(j)
            .Font.Bold = True
            .Font.Color = RGB(255, 255, 255)
            .Interior.Color = RGB(31, 58, 95)
        End With
    Next j
    
    ws.Rows(1).WrapText = True
End Sub

Private Sub RemplirPMP()
    Dim ws As Worksheet
    Dim a As Variant
    Dim parts() As String, mois() As String
    Dim lastVal As Double, refv As Variant
    Dim r As Long
    Dim seriePMP As String, derniere As String
    
    ViderFeuille "PMP"
    Set ws = ThisWorkbook.Worksheets("PMP")
    
    PoserEntete ws, Array("N article", "Famille", "Fournisseurs", "PMP ref 31/12/2024", _
                          "PMP courant 2025", "Nb mois 2025", "Variation PMP vs ref (%)")
    
    r = 2
    
    For Each a In dPMP.Keys
        seriePMP = dPMP(a)
        mois = Split(seriePMP, "|")
        derniere = mois(UBound(mois))
        parts = Split(derniere, ";")
        lastVal = CDbl(parts(1))
        
        refv = Empty
        If Not dRef2024 Is Nothing Then
            If dRef2024.Exists(a) Then refv = dRef2024(a)
        End If
        
        ws.Cells(r, 1).Value = a
        ws.Cells(r, 2).Value = dArtFam(a)
        ws.Cells(r, 3).Value = dArtFour(a)
        
        If IsEmpty(refv) Then
            ws.Cells(r, 4).Value = ""
        Else
            ws.Cells(r, 4).Value = Round(refv, 4)
        End If
        
        ws.Cells(r, 5).Value = Round(lastVal, 4)
        ws.Cells(r, 6).Value = UBound(mois) + 1
        
        If Not IsEmpty(refv) Then
            If refv > 0 Then
                ws.Cells(r, 7).Value = Round((lastVal - refv) / refv * 100, 2)
            End If
        End If
        
        r = r + 1
    Next a
    
    ws.Columns.AutoFit
    ws.Range("A1").Select
End Sub

Private Sub RemplirDerives()
    Dim ws As Worksheet
    Dim c As Variant
    Dim parts() As String, mois() As String, sp() As String
    Dim inflRef As Double, seuil As Double, refPente As Double
    Dim r As Long, n As Long, j As Long
    Dim ind() As Double, base As Double
    Dim penteVal As Double, surcroit As Double, vartot As Double
    Dim ar As String, fo As String
    
    ViderFeuille "Derives"
    Set ws = ThisWorkbook.Worksheets("Derives")
    
    PoserEntete ws, Array("N article", "Fournisseur", "Famille", "Nb mois", _
                          "Pente (pts/mois)", "Surcroit derive (net inflation)", _
                          "Variation totale (%)", "Alerte")
    
    inflRef = ToNum(Param("infl_ref"))
    seuil = ToNum(Param("seuil_derive"))
    refPente = inflRef
    
    r = 2
    
    For Each c In dCoupleSerie.Keys
        mois = Split(dCoupleSerie(c), "|")
        n = UBound(mois) + 1
        
        If n < 3 Then GoTo suivant
        
        ReDim ind(0 To n - 1)
        
        parts = Split(mois(0), ";")
        base = CDbl(parts(1))
        If base <= 0 Then GoTo suivant
        
        For j = 0 To n - 1
            parts = Split(mois(j), ";")
            ind(j) = CDbl(parts(1)) / base * 100
        Next j
        
        penteVal = CalcPente(ind, n)
        surcroit = penteVal - refPente
        vartot = ind(n - 1) - 100
        
        sp = Split(c, "||")
        ar = sp(0)
        fo = sp(1)
        
        ws.Cells(r, 1).Value = ar
        ws.Cells(r, 2).Value = fo
        ws.Cells(r, 3).Value = dArtFam(ar)
        ws.Cells(r, 4).Value = n
        ws.Cells(r, 5).Value = Round(penteVal, 2)
        ws.Cells(r, 6).Value = Round(surcroit, 2)
        ws.Cells(r, 7).Value = Round(vartot, 1)
        
        If surcroit > seuil Then
            ws.Cells(r, 8).Value = "OUI"
            ws.Cells(r, 8).Interior.Color = RGB(198, 40, 40)
            ws.Cells(r, 8).Font.Color = RGB(255, 255, 255)
        Else
            ws.Cells(r, 8).Value = "-"
        End If
        
        r = r + 1
        
suivant:
    Next c
    
    If r > 3 Then
        ws.Range(ws.Cells(1, 1), ws.Cells(r - 1, 8)).Sort _
            Key1:=ws.Cells(1, 6), Order1:=xlDescending, Header:=xlYes
    End If
    
    ws.Columns.AutoFit
End Sub

Private Sub RemplirChocs()
    Dim ws As Worksheet
    Dim a As Variant
    Dim parts() As String, mois() As String
    Dim seuilChoc As Double, obs As Long, tol As Double
    Dim r As Long, n As Long, i As Long
    Dim pmpV() As Double, mkV() As String
    Dim lastEnd As Long, varPct As Double, pre As Double, post As Double
    Dim finIdx As Long, statut As String, ecartFinal As Double
    
    ViderFeuille "Chocs PMP"
    Set ws = ThisWorkbook.Worksheets("Chocs PMP")
    
    PoserEntete ws, Array("N article", "Famille", "Mois choc", "Variation (%)", _
                          "PMP avant", "PMP apres", "Fenetre obs.", _
                          "Ecart final vs pre (%)", "Statut")
    
    seuilChoc = ToNum(Param("seuil_choc"))
    obs = CLng(ToNum(Param("fenetre_obs")))
    tol = ToNum(Param("tol_resorption"))
    
    If obs < 1 Then obs = 2
    
    r = 2
    
    For Each a In dPMP.Keys
        mois = Split(dPMP(a), "|")
        n = UBound(mois) + 1
        
        If n < 2 Then GoTo suivant
        
        ReDim pmpV(0 To n - 1)
        ReDim mkV(0 To n - 1)
        
        For i = 0 To n - 1
            parts = Split(mois(i), ";")
            mkV(i) = parts(0)
            pmpV(i) = CDbl(parts(1))
        Next i
        
        lastEnd = -1
        
        For i = 1 To n - 1
            If i <= lastEnd Then GoTo continuer
            
            pre = pmpV(i - 1)
            post = pmpV(i)
            
            If pre <= 0 Then GoTo continuer
            
            varPct = (post - pre) / pre * 100
            
            If Abs(varPct) >= seuilChoc Then
                finIdx = i + obs
                If finIdx > n - 1 Then finIdx = n - 1
                
                If finIdx - i < obs Then
                    statut = "EN OBSERVATION"
                    ecartFinal = -9999
                Else
                    ecartFinal = (pmpV(finIdx) - pre) / pre * 100
                    If Abs(ecartFinal) <= tol Then
                        statut = "RESORBE"
                    Else
                        statut = "CASSURE CONFIRMEE"
                    End If
                End If
                
                ws.Cells(r, 1).Value = a
                ws.Cells(r, 2).Value = dArtFam(a)
                ws.Cells(r, 3).Value = mkV(i)
                ws.Cells(r, 4).Value = Round(varPct, 1)
                ws.Cells(r, 5).Value = Round(pre, 4)
                ws.Cells(r, 6).Value = Round(post, 4)
                ws.Cells(r, 7).Value = mkV(i) & " -> " & mkV(finIdx)
                
                If ecartFinal <> -9999 Then
                    ws.Cells(r, 8).Value = Round(ecartFinal, 1)
                Else
                    ws.Cells(r, 8).Value = ""
                End If
                
                ws.Cells(r, 9).Value = statut
                
                Select Case statut
                    Case "CASSURE CONFIRMEE"
                        ws.Cells(r, 9).Interior.Color = RGB(198, 40, 40)
                        ws.Cells(r, 9).Font.Color = RGB(255, 255, 255)
                    Case "EN OBSERVATION"
                        ws.Cells(r, 9).Interior.Color = RGB(249, 168, 37)
                    Case "RESORBE"
                        ws.Cells(r, 9).Interior.Color = RGB(232, 245, 233)
                End Select
                
                r = r + 1
                lastEnd = finIdx
            End If
            
continuer:
        Next i
        
suivant:
    Next a
    
    ws.Columns.AutoFit
End Sub

Private Function SurcroitArticle(a As Variant) As Double
    Dim mois() As String, parts() As String
    Dim n As Long, j As Long
    Dim ind() As Double, base As Double
    Dim inflRef As Double
    
    inflRef = ToNum(Param("infl_ref"))
    
    mois = Split(dPMP(a), "|")
    n = UBound(mois) + 1
    
    If n < 3 Then
        SurcroitArticle = -9999
        Exit Function
    End If
    
    ReDim ind(0 To n - 1)
    
    parts = Split(mois(0), ";")
    base = CDbl(parts(1))
    
    If base <= 0 Then
        SurcroitArticle = -9999
        Exit Function
    End If
    
    For j = 0 To n - 1
        parts = Split(mois(j), ";")
        ind(j) = CDbl(parts(1)) / base * 100
    Next j
    
    SurcroitArticle = CalcPente(ind, n) - inflRef
End Function

Private Sub RemplirClassement()
    Dim ws As Worksheet
    Dim a As Variant
    Dim r As Long
    Dim profil As String, justif As String
    Dim surcroit As Double
    Dim mois() As String, parts() As String
    Dim n As Long, pmpCourant As Double
    Dim nFour As Long
    
    ViderFeuille "Classement"
    Set ws = ThisWorkbook.Worksheets("Classement")
    
    PoserEntete ws, Array("N article", "Famille", "Nb fourn.", "Profil", "Justification", _
                          "Surcroit derive", "PMP courant")
    
    r = 2
    
    For Each a In dPMP.Keys
        mois = Split(dPMP(a), "|")
        n = UBound(mois) + 1
        parts = Split(mois(n - 1), ";")
        pmpCourant = CDbl(parts(1))
        nFour = UBound(Split(dArtFour(a), ";")) + 1
        
        ClasserUn a, n, profil, justif, surcroit
        
        ws.Cells(r, 1).Value = a
        ws.Cells(r, 2).Value = dArtFam(a)
        ws.Cells(r, 3).Value = nFour
        ws.Cells(r, 4).Value = profil
        ws.Cells(r, 5).Value = justif
        
        If surcroit <> -9999 Then
            ws.Cells(r, 6).Value = Round(surcroit, 2)
        Else
            ws.Cells(r, 6).Value = ""
        End If
        
        ws.Cells(r, 7).Value = Round(pmpCourant, 4)
        r = r + 1
    Next a
    
    ws.Columns.AutoFit
End Sub

Private Sub ClasserUn(a As Variant, n As Long, ByRef profil As String, ByRef justif As String, ByRef surcroit As Double)
    Dim mois() As String, parts() As String
    Dim j As Long
    Dim pmpV() As Double
    Dim varMax As Double, v As Double
    Dim seuil As Double
    Dim cassure As Boolean, mkCass As String, sautCass As Double
    Dim moyApres As Double
    
    seuil = ToNum(Param("seuil_derive"))
    surcroit = SurcroitArticle(a)
    
    mois = Split(dPMP(a), "|")
    ReDim pmpV(0 To n - 1)
    
    For j = 0 To n - 1
        parts = Split(mois(j), ";")
        pmpV(j) = CDbl(parts(1))
    Next j
    
    varMax = 0
    For j = 1 To n - 1
        If pmpV(j - 1) > 0 Then
            v = Abs((pmpV(j) - pmpV(j - 1)) / pmpV(j - 1) * 100)
            If v > varMax Then varMax = v
        End If
    Next j
    
    For j = 1 To n - 1
        If pmpV(j - 1) > 0 Then
            v = (pmpV(j) - pmpV(j - 1)) / pmpV(j - 1) * 100
            
            If Abs(v) >= 12 And j + 2 <= n - 1 Then
                moyApres = (pmpV(j + 1) + pmpV(j + 2)) / 2
                
                If Abs(moyApres - pmpV(j)) / pmpV(j) * 100 <= 3 Then
                    cassure = True
                    parts = Split(mois(j), ";")
                    mkCass = parts(0)
                    sautCass = v
                End If
            End If
        End If
    Next j
    
    If cassure Then
        profil = "Cassure"
        justif = "Saut " & Format(sautCass, "+0") & "% en " & mkCass & " maintenu"
        Exit Sub
    End If
    
    If surcroit <> -9999 And surcroit > seuil Then
        profil = "Derive franche"
        justif = "Surcroit +" & Format(surcroit, "0.0") & " pts/mois net inflation"
        Exit Sub
    End If
    
    If surcroit <> -9999 And surcroit > -0.3 And surcroit < 0.5 Then
        profil = "Inflation"
        justif = "Pente proche inflation reference"
        Exit Sub
    End If
    
    If varMax < 3 Then
        profil = "Stable"
        justif = "Variation max M/M " & Format(varMax, "0.0") & "%"
        Exit Sub
    End If
    
    profil = "Variable"
    justif = "Variation max M/M " & Format(varMax, "0.0") & "% (non classe)"
End Sub

Private Sub RemplirPilotage()
    Dim ws As Worksheet
    Dim a As Variant
    Dim parts() As String, mois() As String
    Dim sv As Double, sr As Double
    Dim r As Long, n As Long
    Dim pmpCourant As Double
    Dim refv As Variant, ecPMP As Variant, ecCmd As Variant
    Dim zone As String
    
    Dim arr As Variant, nn As Long, i As Long
    Dim dDerniere As Object, dDerniereMk As Object
    Dim art As String, mk As String, p As Double
    
    ViderFeuille "Pilotage"
    Set ws = ThisWorkbook.Worksheets("Pilotage")
    
    PoserEntete ws, Array("N article", "Famille", "Fournisseurs", "PMP ref 31/12/2024", _
                          "PMP courant", "Ecart PMP vs ref (%)", "Prix derniere cmd", _
                          "Ecart cmd vs PMP (%)", "Zone")
    
    sv = ToNum(Param("seuil_vj"))
    sr = ToNum(Param("seuil_jr"))
    
    r = 2
    
    Set dDerniere = CreateObject("Scripting.Dictionary")
    Set dDerniereMk = CreateObject("Scripting.Dictionary")
    
    nn = LireDonnees("Donnees 2025", arr)
    
    For i = 1 To nn
        art = Trim(CStr(arr(i, C_ART)))
        mk = MonthKey(arr(i, C_DATE))
        
        If art <> "" And Left$(mk, 4) = "2025" Then
            p = ToNum(arr(i, C_PRIX))
            
            If p > 0 Then
                If Not dDerniereMk.Exists(art) Then
                    dDerniere(art) = p
                    dDerniereMk(art) = mk
                ElseIf mk >= dDerniereMk(art) Then
                    dDerniere(art) = p
                    dDerniereMk(art) = mk
                End If
            End If
        End If
    Next i
    
    For Each a In dPMP.Keys
        mois = Split(dPMP(a), "|")
        n = UBound(mois) + 1
        parts = Split(mois(n - 1), ";")
        pmpCourant = CDbl(parts(1))
        
        refv = Empty
        If Not dRef2024 Is Nothing Then
            If dRef2024.Exists(a) Then refv = dRef2024(a)
        End If
        
        ecPMP = Empty
        ecCmd = Empty
        
        If Not IsEmpty(refv) Then
            If refv > 0 Then ecPMP = (pmpCourant - refv) / refv * 100
        End If
        
        If dDerniere.Exists(a) And pmpCourant > 0 Then
            ecCmd = (dDerniere(a) - pmpCourant) / pmpCourant * 100
        End If
        
        zone = ZoneDe(ecPMP, ecCmd, sv, sr)
        
        ws.Cells(r, 1).Value = a
        ws.Cells(r, 2).Value = dArtFam(a)
        ws.Cells(r, 3).Value = dArtFour(a)
        
        If IsEmpty(refv) Then
            ws.Cells(r, 4).Value = ""
        Else
            ws.Cells(r, 4).Value = Round(refv, 4)
        End If
        
        ws.Cells(r, 5).Value = Round(pmpCourant, 4)
        
        If IsEmpty(ecPMP) Then
            ws.Cells(r, 6).Value = ""
        Else
            ws.Cells(r, 6).Value = Round(ecPMP, 2)
        End If
        
        If dDerniere.Exists(a) Then
            ws.Cells(r, 7).Value = Round(dDerniere(a), 4)
        Else
            ws.Cells(r, 7).Value = ""
        End If
        
        If IsEmpty(ecCmd) Then
            ws.Cells(r, 8).Value = ""
        Else
            ws.Cells(r, 8).Value = Round(ecCmd, 2)
        End If
        
        ws.Cells(r, 9).Value = zone
        
        Select Case zone
            Case "ROUGE"
                ws.Cells(r, 9).Interior.Color = RGB(198, 40, 40)
                ws.Cells(r, 9).Font.Color = RGB(255, 255, 255)
            Case "JAUNE"
                ws.Cells(r, 9).Interior.Color = RGB(249, 168, 37)
            Case "VERTE"
                ws.Cells(r, 9).Interior.Color = RGB(232, 245, 233)
        End Select
        
        r = r + 1
    Next a
    
    If r > 3 Then
        ws.Range(ws.Cells(1, 1), ws.Cells(r - 1, 9)).Sort _
            Key1:=ws.Cells(1, 9), Order1:=xlAscending, Header:=xlYes
    End If
    
    ws.Columns.AutoFit
End Sub

Private Function ZoneDe(ec1 As Variant, ec2 As Variant, sv As Double, sr As Double) As String
    Dim z1 As Long, z2 As Long, zmax As Long
    
    z1 = ZoneRang(ec1, sv, sr)
    z2 = ZoneRang(ec2, sv, sr)
    
    zmax = z1
    If z2 > zmax Then zmax = z2
    
    Select Case zmax
        Case 0: ZoneDe = ""
        Case 1: ZoneDe = "VERTE"
        Case 2: ZoneDe = "JAUNE"
        Case 3: ZoneDe = "ROUGE"
    End Select
End Function

Private Function ZoneRang(ec As Variant, sv As Double, sr As Double) As Long
    Dim a As Double
    
    If IsEmpty(ec) Then
        ZoneRang = 0
        Exit Function
    End If
    
    a = Abs(CDbl(ec))
    
    If a <= sv Then
        ZoneRang = 1
    ElseIf a <= sr Then
        ZoneRang = 2
    Else
        ZoneRang = 3
    End If
End Function
