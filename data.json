Option Explicit

Private Const C_DATE As Long = 1
Private Const C_ART As Long = 2
Private Const C_DESIG As Long = 3
Private Const C_FOUR As Long = 4
Private Const C_CODEFOUR As Long = 5
Private Const C_FAM As Long = 6
Private Const C_GAMME As Long = 7
Private Const C_QTE As Long = 8
Private Const C_PRIX As Long = 9
Private Const C_STD As Long = 10

Private dPMP As Object
Private dRef2024 As Object
Private dQte2024 As Object
Private dCoupleSerie As Object
Private dArtFam As Object
Private dArtFour As Object

Private Function MonthKey(ByVal v As Variant) As String
    Dim s As String, parts() As String
    Dim d As Long, m As Long, y As Long
    
    MonthKey = ""
    If IsEmpty(v) Or v = "" Then Exit Function
    
    If IsDate(v) Then
        MonthKey = Format(CDate(v), "yyyy-mm")
        Exit Function
    End If
    
    s = Trim(CStr(v))
    s = Replace(Replace(s, "-", "/"), ".", "/")
    
    If InStr(s, "/") > 0 Then
        parts = Split(s, "/")
        
        If UBound(parts) = 2 Then
            d = Val(parts(0))
            m = Val(parts(1))
            y = Val(parts(2))
            
            If y < 100 Then
                If y < 70 Then
                    y = y + 2000
                Else
                    y = y + 1900
                End If
            End If
            
            If m >= 1 And m <= 12 Then
                MonthKey = Format(y, "0000") & "-" & Format(m, "00")
            End If
            
        ElseIf UBound(parts) = 1 Then
            m = Val(parts(0))
            y = Val(parts(1))
            
            If y < 100 Then y = y + 2000
            
            If m >= 1 And m <= 12 Then
                MonthKey = Format(y, "0000") & "-" & Format(m, "00")
            End If
        End If
    End If
End Function

Private Function ToNum(ByVal v As Variant) As Double
    Dim s As String
    
    On Error GoTo fail
    
    If IsNumeric(v) Then
        ToNum = CDbl(v)
        Exit Function
    End If
    
    s = Trim(CStr(v))
    s = Replace(s, " ", "")
    s = Replace(s, Chr(160), "")
    s = Replace(s, ",", ".")
    
    If IsNumeric(s) Then
        ToNum = CDbl(s)
    Else
        ToNum = 0
    End If
    Exit Function
    
fail:
    ToNum = 0
End Function

Private Function LireDonnees(ByVal nomFeuille As String, ByRef arr As Variant) As Long
    Dim ws As Worksheet
    Dim lastRow As Long
    
    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets(nomFeuille)
    On Error GoTo 0
    
    If ws Is Nothing Then
        LireDonnees = 0
        Exit Function
    End If
    
    lastRow = ws.Cells(ws.Rows.Count, C_ART).End(xlUp).Row
    If lastRow < 2 Then
        LireDonnees = 0
        Exit Function
    End If
    
    arr = ws.Range(ws.Cells(2, 1), ws.Cells(lastRow, C_STD)).Value
    LireDonnees = lastRow - 1
End Function

Private Function Param(ByVal nom As String) As Variant
    On Error Resume Next
    Param = ThisWorkbook.Names(nom).RefersToRange.Value
    On Error GoTo 0
End Function

Private Sub ViderFeuille(ByVal nom As String)
    Dim ws As Worksheet
    
    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets(nom)
    On Error GoTo 0
    
    If Not ws Is Nothing Then ws.Cells.Clear
End Sub

Private Function CalcPente(ByRef y() As Double, ByVal n As Long) As Double
    Dim i As Long
    Dim sx As Double, sy As Double, sxy As Double, sxx As Double
    Dim mx As Double, my As Double
    
    If n < 2 Then
        CalcPente = 0
        Exit Function
    End If
    
    For i = 0 To n - 1
        sx = sx + i
        sy = sy + y(i)
    Next i
    
    mx = sx / n
    my = sy / n
    
    For i = 0 To n - 1
        sxy = sxy + (i - mx) * (y(i) - my)
        sxx = sxx + (i - mx) * (i - mx)
    Next i
    
    If sxx = 0 Then
        CalcPente = 0
    Else
        CalcPente = sxy / sxx
    End If
End Function

Private Sub CalculerRef2024()
    Dim arr As Variant, n As Long, i As Long
    Dim accCV As Object, accCQ As Object, accNb As Object
    Dim accLast As Object, accLastMk As Object
    Dim art As String, mk As String
    Dim p As Double, q As Double
    Dim k As Variant
    
    Set dRef2024 = CreateObject("Scripting.Dictionary")
    Set dQte2024 = CreateObject("Scripting.Dictionary")
    
    n = LireDonnees("Donnees 2024", arr)
    If n = 0 Then Exit Sub
    
    Set accCV = CreateObject("Scripting.Dictionary")
    Set accCQ = CreateObject("Scripting.Dictionary")
    Set accNb = CreateObject("Scripting.Dictionary")
    Set accLast = CreateObject("Scripting.Dictionary")
    Set accLastMk = CreateObject("Scripting.Dictionary")
    
    For i = 1 To n
        art = Trim(CStr(arr(i, C_ART)))
        mk = MonthKey(arr(i, C_DATE))
        
        If art <> "" And Left$(mk, 4) = "2024" Then
            p = ToNum(arr(i, C_PRIX))
            q = ToNum(arr(i, C_QTE))
            
            If p > 0 And q > 0 Then
                accCV(art) = accCV(art) + p * q
                accCQ(art) = accCQ(art) + q
                accNb(art) = accNb(art) + 1
                
                If mk >= "2024-09" Then
                    If Not accLastMk.Exists(art) Then
                        accLast(art) = p
                        accLastMk(art) = mk
                    ElseIf mk >= accLastMk(art) Then
                        accLast(art) = p
                        accLastMk(art) = mk
                    End If
                End If
            End If
        End If
    Next i
    
    For Each k In accCQ.Keys
        dQte2024(k) = accCQ(k)
        
        If accNb(k) >= 2 And accCQ(k) > 0 Then
            dRef2024(k) = accCV(k) / accCQ(k)
        ElseIf accLast.Exists(k) Then
            dRef2024(k) = accLast(k)
        ElseIf accCQ(k) > 0 Then
            dRef2024(k) = accCV(k) / accCQ(k)
        End If
    Next k
End Sub

Private Sub CalculerSeriesPMP()
    Dim arr As Variant, n As Long, i As Long
    Dim artMoisCV As Object, artMoisCQ As Object
    Dim cplCV As Object, cplCQ As Object
    Dim artMois As Object, cplMois As Object
    
    Dim art As String, four As String, fam As String, mk As String
    Dim p As Double, q As Double
    Dim keyAM As String, keyCM As String, cpl As String
    
    Dim a As Variant, c As Variant
    Dim moisArr() As String
    Dim j As Long
    Dim cv As Double, cq As Double
    Dim serie As String
    Dim poids As Double
    
    n = LireDonnees("Donnees 2025", arr)
    
    Set dPMP = CreateObject("Scripting.Dictionary")
    Set dCoupleSerie = CreateObject("Scripting.Dictionary")
    Set dArtFam = CreateObject("Scripting.Dictionary")
    Set dArtFour = CreateObject("Scripting.Dictionary")
    
    If n = 0 Then Exit Sub
    
    Set artMoisCV = CreateObject("Scripting.Dictionary")
    Set artMoisCQ = CreateObject("Scripting.Dictionary")
    Set cplCV = CreateObject("Scripting.Dictionary")
    Set cplCQ = CreateObject("Scripting.Dictionary")
    Set artMois = CreateObject("Scripting.Dictionary")
    Set cplMois = CreateObject("Scripting.Dictionary")
    
    For i = 1 To n
        art = Trim(CStr(arr(i, C_ART)))
        mk = MonthKey(arr(i, C_DATE))
        
        If art = "" Or Left$(mk, 4) <> "2025" Then GoTo suite
        
        p = ToNum(arr(i, C_PRIX))
        q = ToNum(arr(i, C_QTE))
        
        If p <= 0 Or q <= 0 Then GoTo suite
        
        four = Trim(CStr(arr(i, C_FOUR)))
        If four = "" Then four = "(inconnu)"
        
        fam = Trim(CStr(arr(i, C_FAM)))
        If fam = "" Then fam = four
        
        dArtFam(art) = fam
        
        If Not dArtFour.Exists(art) Then
            dArtFour(art) = four
        ElseIf InStr(1, ";" & dArtFour(art) & ";", ";" & four & ";", vbTextCompare) = 0 Then
            dArtFour(art) = dArtFour(art) & ";" & four
        End If
        
        keyAM = art & "|" & mk
        artMoisCV(keyAM) = artMoisCV(keyAM) + p * q
        artMoisCQ(keyAM) = artMoisCQ(keyAM) + q
        
        If Not artMois.Exists(art) Then
            artMois(art) = mk
        Else
            If InStr(1, "|" & artMois(art) & "|", "|" & mk & "|", vbTextCompare) = 0 Then
                artMois(art) = artMois(art) & "|" & mk
            End If
        End If
        
        cpl = art & "||" & four
        keyCM = cpl & "|" & mk
        cplCV(keyCM) = cplCV(keyCM) + p * q
        cplCQ(keyCM) = cplCQ(keyCM) + q
        
        If Not cplMois.Exists(cpl) Then
            cplMois(cpl) = mk
        Else
            If InStr(1, "|" & cplMois(cpl) & "|", "|" & mk & "|", vbTextCompare) = 0 Then
                cplMois(cpl) = cplMois(cpl) & "|" & mk
            End If
        End If
        
suite:
    Next i
    
    For Each a In artMois.Keys
        moisArr = Split(artMois(a), "|")
        TriBulle moisArr
        
        cv = 0
        cq = 0
        
        If Not dRef2024 Is Nothing Then
            If dRef2024.Exists(a) Then
                poids = 1
                If Not dQte2024 Is Nothing Then
                    If dQte2024.Exists(a) Then poids = dQte2024(a)
                End If
                If poids <= 0 Then poids = 1
                
                cv = dRef2024(a) * poids
                cq = poids
            End If
        End If
        
        serie = ""
        For j = 0 To UBound(moisArr)
            keyAM = a & "|" & moisArr(j)
            cv = cv + artMoisCV(keyAM)
            cq = cq + artMoisCQ(keyAM)
            
            If cq > 0 Then
                serie = serie & IIf(serie = "", "", "|") & moisArr(j) & ";" & (cv / cq)
            End If
        Next j
        
        dPMP(a) = serie
    Next a
    
    For Each c In cplMois.Keys
        moisArr = Split(cplMois(c), "|")
        TriBulle moisArr
        
        serie = ""
        For j = 0 To UBound(moisArr)
            keyCM = c & "|" & moisArr(j)
            If cplCQ(keyCM) > 0 Then
                serie = serie & IIf(serie = "", "", "|") & moisArr(j) & ";" & (cplCV(keyCM) / cplCQ(keyCM))
            End If
        Next j
        
        dCoupleSerie(c) = serie
    Next c
End Sub

Private Sub TriBulle(ByRef a() As String)
    Dim i As Long, j As Long
    Dim tmp As String
    
    For i = LBound(a) To UBound(a) - 1
        For j = i + 1 To UBound(a)
            If a(j) < a(i) Then
                tmp = a(i)
                a(i) = a(j)
                a(j) = tmp
            End If
        Next j
    Next i
End Sub

